import numpy as np
import matplotlib.pyplot as plt
from collections import Counter


data = np.random.rand(100)


train_x = data[:50]
train_y = ["Class1" if x <= 0.5 else "Class2" for x in train_x]


test_x = data[50:]


def knn(train_x, train_y, point, k):
    distances = [(abs(point - x), y) for x, y in zip(train_x, train_y)]
    nearest = sorted(distances)[:k]
    labels = [y for _, y in nearest]
    return Counter(labels).most_common(1)[0][0]


for k in [1, 3, 5]:
    predictions = [knn(train_x, train_y, x, k) for x in test_x]

    
    plt.figure(figsize=(8, 4))
    plt.scatter(train_x, [0]*50,
                c=["blue" if y=="Class1" else "red" for y in train_y],
                label="Train")

    plt.scatter(test_x, [1]*50,
                c=["blue" if y=="Class1" else "red" for y in predictions],
                marker="x", label="Test")

    plt.title(f"k-NN (k={k})")
    plt.yticks([0,1], ["Train","Test"])
    plt.grid(True)
    plt.legend()
    plt.show()

    



